# Salin ke .env.local lalu isi nilainya. Semua NEXT_PUBLIC_* ikut ke bundle
# browser saat build (bersifat publik), jadi JANGAN taruh secret server di sini.

# URL situs (dipakai sitemap/SEO)
NEXT_PUBLIC_SITE_URL=https://wedison.co

# EmailJS (form kontak) — https://dashboard.emailjs.com
NEXT_PUBLIC_EMAIL_CONFIG_serviceId=service_xxxxxxx
NEXT_PUBLIC_EMAIL_CONFIG_templateId=template_xxxxxxx
NEXT_PUBLIC_EMAIL_CONFIG_publicKey=xxxxxxxxxxxxxxxx

# Google reCAPTCHA v2 ("I'm not a robot") — site key saja (publik).
# Secret key TIDAK di sini; masukkan di dashboard EmailJS (Template > Settings).
# Kosongkan untuk menonaktifkan reCAPTCHA (form tetap berfungsi).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
